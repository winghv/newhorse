# =============================================================
# Newhorse Environment Configuration
# =============================================================
# Copy this file:  cp .env.example .env          (local dev)
#                  cp .env.example .env.docker    (Docker)
#
# API keys are stored ENCRYPTED in the database. You can also
# configure them later via the web UI (Settings > Providers).
# =============================================================

# ---- Database ----
# DATABASE_URL=sqlite:///data/newhorse.db

# ---- Encryption (optional, strongly recommended for production) ----
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# ---- Server ----
# API_PORT=8080
# THS_TIER=dev

# ---- Storage paths (usually no need to change) ----
# PROJECTS_ROOT=data/projects
# AGENTS_ROOT=data/agents
